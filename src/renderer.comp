// ========================================
// RENDERER CODE
// ========================================
void main() {
    // GRAB THREAD'S PIXEL
    ivec2 pixelCoords = ivec2(gl_GlobalInvocationID.xy);
    
    // CHECK IF OUTSIDE RESOLUTION DIMENSIONS
    ivec2 dims = imageSize(screenOutput);
    if(pixelCoords.x >= dims.x || pixelCoords.y >= dims.y) {
        return;
    }

    // ----------------------------------------
    // CAMERA SETUP
    // ----------------------------------------
    // INSTANTIATE STRUCTS
    Camera cam;
    Basis basis;
    Viewport viewport;
    Image image;

    // PASS VARIABLES
    cam.origin = CameraData.camOrigin;
    cam.lensDiameter = CameraData.lensDiameter;
    cam.focusDist = CameraData.focusDist;
    basis.xhat = CameraData.xhat;
    basis.yhat = CameraData.yhat;
    viewport.origin = CameraData.origin;
    image.width = 640;
    image.height = 640;

    // PATH TRACING CALCULATIONS
    //vec3 finalColor = calculateRay();
    vec3 finalColor = vec3(1, 0, 0);
    
    // STORE IMAGE
    imageStore(screenOutput, pixelCoords, vec4(finalColor, 1.0));
}

// ========================================
// RAY GENERATION
// ========================================
Ray rayGeneration(float i, float j, Camera camera, Ray ray, Basis basis, Viewport viewport, Image image)
{
    // Pixel Sample
    randSample = (uint(i) * uint(image.pixelWidth)) + uint(j);

    vec3 smpleSqr = vec3(RandFloat(randSample) - 0.5f, RandFloat(randSample) - 0.5f, 0.0); // random point in sample area
    vec3 pixelOffset = smpleSqr;

    // Jitter The Pixel
    vec2 jitter = vec2(RandFloat(randSample), RandFloat(randSample)); // randomize the sample position
    float jitterX = i + jitter.x;
    float jitterY = j + jitter.y;

    // Find Ray Direction (Pinhole)
    vec3 pixelPos = camera.origin + (jitterX * image.pixelWidth * basis.xhat) +
                         (jitterY * image.pixelHeight * basis.yhat);
    ray.direction = normalize(pixelPos - camera.origin); // Calculated by geting normalized unit of the vector between ray origin and camera origin

    // DEPTH OF FIELD CALCUlATIONS (Lens)
    vec3 focalPoint = camera.origin + (ray.direction * camera.focusDist); // focal point from the focus point and the focus distance
    vec3 lensSample = lensRandom() * (camera.lensDiameter / 2.0); // grab random value within the lens radius

    // Ray Origin
    ray.origin = camera.origin + (lensSample.x * basis.xhat) + (lensSample.y * basis.yhat); // moves ray origin back to camera origin

    // Ray Direction
    ray.direction = normalize(focalPoint - ray.origin);

    // Get a Random Time (Motion Blur)
    ray.time = RandFloat(randSample);

    return ray;
}

// ========================================
// LENS POINT
// ========================================
vec3 lensRandom()
{
    while (true)
    {
        // Generate Random Point Within -1 and 1
        vec3 point = vec3(RandFloat(randSample) * 2.0 - 1.0, RandFloat(randSample) * 2.0 - 1.0, 0.0);

        // Check For Point Inside Lens
        if (dot(point, point) < 1.0)
            return point;
    }
}

// ========================================
// HELPER FUNCTIONS
// ========================================

// ----------------------------------------
// RANDOM NUMBER GENERATOR (HASHING)
// ----------------------------------------
float RandFloat(uint i)
{
    i += rngState;
    // MULTIPLE BY LARGE 32 BIT NUMBER
    uint val = i * 234023487u;

    // BIT SHIFT (SHIFT THE NUMBERS AROUND)
    uint bitVal = val >> 4;

    // BLEND VALUES
    uint hashVal = val ^ bitVal; // xor together

    // INCREMENT RNG STATE
    rngState++;

    return float(hashVal) / 4294967295.0; // cap it to 0-1
}

// ----------------------------------------
// FRESNEL REFLECTANCE
// ----------------------------------------
vec3 FrsRflct(vec3 normal, vec3 direction, vec3 F0)
{
    float cosTheta = clamp(dot(normal, direction), 0.0, 1.0);
    vec3 Fr = F0 + (1.0 - F0) * pow((1.0 - cosTheta), 5.0);
    return Fr;
}

// ----------------------------------------
// NORMAL DISTRIBUTION FUNCTION 
// ----------------------------------------
// Approx relative surface area of microfacets exactly aligned to the halfway vector wh (from learnopengl)
// ROUGH SPECULAR (Trowbridge-Reitz)
float DistrFunc(float alphaSqr, vec3 normal, vec3 wh)
{
    float D = alphaSqr / (pi * ((dot(normal, wh) * dot(normal, wh)) * (alphaSqr - 1) + 1));
    return D;
}

// ----------------------------------------
// Geometry Function 
// ----------------------------------------
// Approx relative surface area where micro surface details overshadow each other, causing light rays to be covered (from opengl)
float GeomFunc(float k, vec3 normal, vec3 w0, vec3 wi)
{
    float w0HalfVec = dot(normal, w0) / (dot(normal, w0) * (1 - k) + k);
    float wiHalfVec = dot(normal, wi) / (dot(normal, wi) * (1 - k) + k);
    float G = max(w0HalfVec, 0.0) * max(wiHalfVec, 0.0); // clamped to prevent negative light (light from behind object)
    return G;
}

// ----------------------------------------
// LAYERED BSDF
// ----------------------------------------
// Random Instead of Deterministic
vec3 LayeredBxDF(HitInfo hitInfo, vec3 w0, inout vec3 wi, inout float pdf)    // WI and PDF WERE REFERENCES
{
    int maxDepth = 5;

    // Top Layer Hit
    HitInfo topLayer = hitInfo;

    topLayer.roughness = 0.0;
    topLayer.metallic = 0.0;
    topLayer.ior = hitInfo.layerIOR;
    topLayer.albedo = vec3(1.0);

    // BxDF CALL
    vec3 f = BxDF(topLayer, w0, wi, pdf); // initial check for if entered layer of not

    // Outside Check
    float cosThetaOut = dot(wi, hitInfo.normal);
    float cosThetaIn = dot(w0, hitInfo.normal);

    // REFLECTED
    if (wi.z > 0.0 && w0.z > 0.0)
    {
        return f; // return BxDF
    }

    // TRANSMITTED
    vec3 w; // current direction
    w = wi;      // starting direction
    float z = hitInfo.z;

    // RANDOM WALK
    for (int depth = 0; depth < maxDepth; ++depth)
    {
        // Beer's Law Absorbance
        float distance = hitInfo.z / abs(w.z);
        float cosThetaW = dot(w, hitInfo.normal);
        f *= exp(-distance);

        // Boundary Hit Check
        HitInfo crntHit = hitInfo;

        // Bottom Boundary
        if (z == 0.0)
        {
            crntHit = hitInfo;
        }
        // Top Boundary
        else
        {
            crntHit = topLayer;
        }

        // Bounce
        float pdfBounce = 0.0;
        vec3 color = BxDF(crntHit, -w, wi, pdfBounce);
        f *= color;
        pdf *= pdfBounce;
        w = wi;

        cosThetaW = dot(w, hitInfo.normal);

        // Escape Check
        if (cosThetaW < 0.0 && z == hitInfo.z)
        {
            break;
        }
    }

    return vec3(0.0);
}

// ----------------------------------------
// DIRECT LIGHTING BRDF
// ----------------------------------------
vec3 DirectBxDF(HitInfo hitInfo, vec3 w0, vec3 wi)
{
    // PERFECT SMOOTH CHECK (Dirac Delta)
    if (hitInfo.roughness == 0.0)
    {
        return vec3(0.0);
    }

    float nDotW0 = dot(hitInfo.normal, w0);
    float nDotWi = dot(hitInfo.normal, wi);

    // Early Exit
    if (nDotW0 <= 0.0 || nDotWi <= 0.0)
    {
        return vec3(0.0);
    }

    vec3 wh = normalize(w0 + wi); // half-way vector

    // IDEAL SPECULAR
    // Fresnel Schlick Approx (Calculate Reflection Based On Incident Angle)
    vec3 F0 = vec3(0.04f);
    if (hitInfo.metallic > 0.0)
    {
        F0 = mix(F0, hitInfo.albedo, hitInfo.metallic); // mix the fresnel reflection with the base color based on how metallic object is
    }

    // ROUGH SPECULAR (Direction Diffuse)

    // Trowbridge Reitz (Normal Distr Function)
    float alpha = max(hitInfo.roughness, 0.01f); // roughness parameter
    float alphaSqr = alpha * alpha;
    float k = (alphaSqr + 1.0) / 8.0;
    float D = DistrFunc(alphaSqr, hitInfo.normal, wh); // how aligned surface normal is with microfacet normals
    float G = GeomFunc(k, hitInfo.normal, w0, wi);     // how much masking, shadowing, interreflection due to facet distribution

    // Rough Specular BRDF
    vec3 Fr = FrsRflct(wh, w0, F0);
    vec3 roughSpec = (D * G * Fr) / (4.0 * nDotW0 * nDotWi);

    // Ideal Diffuse
    vec3 kD = vec3(1.0) - Fr;
    kD *= (1.0 - hitInfo.metallic);
    vec3 idealDiffuse = (kD * hitInfo.albedo) / pi;

    // PBR BRDF RESULT (Direct Lighting)
    vec3 directLighting = idealDiffuse + roughSpec;

    return directLighting;
}

// ----------------------------------------
// BxDF
// ----------------------------------------
vec3 BxDF(HitInfo hitInfo, vec3 w0, inout vec3 wi, inout float pdf)
{
    // Variables
    float ior = hitInfo.ior;
    vec3 normal = hitInfo.normal;
    vec3 albedo = hitInfo.albedo;
    float nDotw0 = dot(hitInfo.normal, w0);
    vec3 Fr;
    vec3 F0 = vec3(0.04f);

    // SMOOTH SPECULAR
    if (hitInfo.roughness == 0.0 && (ior > 1.0 || hitInfo.metallic > 0.0))
    {
        // Smooth Dielectric
        if (ior > 1.0)
        {
            // Inside / Outside Check
            bool outside = dot(w0, normal) > 0.0;
            vec3 n = outside ? normal : -normal;
            float eta = outside ? (1.0 / ior) : ior;
            float cosTheta;

            // CORRECTED SCHLICK APPROXIMATION
            F0 = vec3(pow((ior - 1) / (ior + 1), 2.0));

            // Variables
            Fr = FrsRflct(n, w0, F0);
            float uc = RandFloat(randSample);
            float pt = 1.0 - Fr.r;

            // DISCRETE SAMPLING
            // Perfect Specular Reflection
            if (uc < (Fr.r / (Fr.r + pt)))
            {
                wi = reflect(-w0, n);
                pdf = 1.0;
                cosTheta = max(abs(dot(n, wi)), 0.001f);
                return vec3(1.0);
            }
            // Perfect Specular Transmission
            else
            {
                wi = refract(-w0, n, eta);

                // Catch Grazing Angle (Total Internal Reflection)
                if (length(wi) == 0.0)
                {
                    wi = reflect(-w0, n);
                }

                pdf = 1.0;
                cosTheta = max(abs(dot(n, wi)), 0.001f);
                return vec3(1.0);
            }
        }
        // Smooth Conductor
        else if (hitInfo.metallic > 0.0)
        {
            // CORRECTED SCHLICK APPROXIMATION
            F0 = albedo;

            wi = reflect(-w0, normal);

            // BSDF CALCULATION
            // return Fr / abs(nDotw0);
            Fr = FrsRflct(normal, w0, F0);

            pdf = 1.0;
            float cosTheta = max(abs(dot(normal, wi)), 0.001f);
            return Fr;
        }
    }
    // ROUGH SPECULAR
    else
    {
        // COS WEIGHTED UIT HEMISPHERE SAMPLING (IMPORTANCE SAMPLING)
        // Random Variables
        float Xi0 = RandFloat(randSample);
        float Xi1 = RandFloat(randSample);

        // Uniform Disc Sample
        float dXi0 = 2 * Xi0 - 1.0;
        float dXi1 = 2 * Xi1 - 1.0;
        float r;
        float theta;

        // Prevent Division By Zero
        if (dXi0 == 0 && dXi1 == 0)
        {
            r = 0.0;
            theta = 0.0;
        }

        else if (abs(dXi0) > abs(dXi1))
        {
            theta = (pi / (4.0)) * (dXi1 / dXi0);
            r = dXi0;
        }
        else
        {
            theta = (pi / (2.0)) - (pi / (4.0)) * (dXi0 / dXi1);
            r = dXi1;
        }

        // Project Point Onto Hemisphere
        wi.x = r * cos(theta);
        wi.y = r * sin(theta);
        wi.z = sqrt(1 - r * r);

        // PDF / PROBABILITY
        // Sampling and Direction Probability (Cosine Weighted)
        pdf = wi.z / pi;
        pdf = max(pdf, 0.001f);

        // Convert wi To World Space
        // Axis Calculation
        vec3 normUp = (abs(hitInfo.normal.z) < 0.999f) ? vec3(0, 0, 1) : vec3(1, 0, 0);
        vec3 orthoU = normalize(cross(normUp, hitInfo.normal));
        vec3 orthoUp = cross(orthoU, hitInfo.normal);

        // Rotation Matrix
        mat3 localSpace = mat3(orthoU, orthoUp, hitInfo.normal);

        // Rotate Into World Space
        wi = normalize(localSpace * wi);

        // Trowbridge Reitz (Normal Distr Function)
        vec3 wh = normalize(0.5f * (w0 + wi));      // half way vector
        float alpha = max(hitInfo.roughness, 0.01f); // roughness parameter
        float alphaSqr = alpha * alpha;
        float k = (alphaSqr + 1.0) / 8.0;
        float D = DistrFunc(alphaSqr, hitInfo.normal, wh); // how aligned surface normal is with microfacet normals
        float G = GeomFunc(k, hitInfo.normal, w0, wi);     // how much masking, shadowing, interreflection due to facet distribution
        float h;

        // ROUGH CONDUCTOR
        if (hitInfo.metallic > 0.0)
        {
            // F0 = (pow(ior - 1.0, 2.0) + (albedo * albedo)) / (pow(ior + 1.0, 2.0) + (albedo * albedo));
            F0 = albedo;

            // GGX SAMPLING
            alpha = max(hitInfo.roughness, 0.01f); // roughness parameter
            alphaSqr = alpha * alpha;

            // Random Point In Uniform Disk
            float phi = 2.0 * pi * Xi0;
            float cosTheta = sqrt((1.0 - Xi1) / (1.0 + (alphaSqr - 1.0) * Xi1));
            float sinTheta = sqrt(max(0.0, 1.0 - cosTheta * cosTheta));

            wh.x = sinTheta * cos(phi); // random point on x
            wh.y = sinTheta * sin(phi); // random point on y
            wh.z = cosTheta;

            // Local To World Transform
            wh = normalize(orthoU * wh.x + orthoUp * wh.y + hitInfo.normal * wh.z);

            wi = reflect(-w0, wh); // final outgoing vector (bounce direction)

            // Normal Check
            if (dot(wi, hitInfo.normal) <= 0.0)
            {
                return vec3(0.0);
            }

            float k = (alphaSqr + 1.0) / 8.0;
            float D = DistrFunc(alphaSqr, hitInfo.normal, wh); // how aligned surface normal is with microfacet normals
            float G = GeomFunc(k, hitInfo.normal, w0, wi);     // how much masking, shadowing, interreflection due to facet distribution

            float nDotw0 = max(dot(hitInfo.normal, w0), 0.001f);
            float nDotwi = max(dot(hitInfo.normal, wi), 0.001f);
            float nDotwh = max(dot(hitInfo.normal, wh), 0.001f);
            float w0Dotwh = max(dot(w0, wh), 0.001f);

            // PDF
            pdf = (D * nDotwh) / (4.0 * w0Dotwh);
            pdf = max(pdf, 0.001f);

            // BRDF Calculations
            vec3 Fr = FrsRflct(wh, w0, F0);
            vec3 roughSpec = (D * G * Fr) / (4.0 * nDotw0 * nDotwi);

            return roughSpec;
        }

        // ROUGH DIELECTRIC
        else if (hitInfo.ior > 1.0)
        {
            // CORRECTED SCHLICK APPROXIMATION
            F0 = vec3(pow((ior - 1.0) / (ior + 1.0), 2.0));

            // Random Numbers
            float xiPhi = RandFloat(randSample);
            float xiTheta = RandFloat(randSample);
            float xi0 = RandFloat(randSample);

            // GGX SAMPLING
            float alpha = max(hitInfo.roughness, 0.01f);
            float alphaSqr = alpha * alpha;

            // Random Point In Uniform Disk
            float phi = 2.0 * pi * xiPhi;
            float cosTheta = sqrt((1.0 - xiTheta) / (1.0 + (alphaSqr - 1.0) * xiTheta));
            float sinTheta = sqrt(max(0.0, 1.0 - cosTheta * cosTheta));

            wh.x = sinTheta * cos(phi);
            wh.y = sinTheta * sin(phi);
            wh.z = cosTheta;

            // Local To World Transform
            wh = normalize(orthoU * wh.x + orthoUp * wh.y + hitInfo.normal * wh.z);

            if (dot(wh, w0) < 0.0)
            {
                wh = -wh;
            }

            // Inside / Outside Check
            float etaI = 1.0;
            float etaT = hitInfo.ior;
            bool outside = dot(w0, normal) > 0.0;
            vec3 n = outside ? normal : -normal;
            float eta = outside ? (etaI / etaT) : (etaT / etaI);

            // Fresnel Reflection
            float Fr = FrsRflct(wh, w0, F0).r;

            // REFLECT CHANCE
            if (xi0 <= Fr)
            {
                // Reflect
                wi = reflect(-w0, wh);

                if (dot(wi, hitInfo.normal) <= 0.0)
                    return vec3(0.0);

                float k = (alphaSqr + 1.0) / 8.0;
                float D_new = DistrFunc(alphaSqr, hitInfo.normal, wh);
                float G_new = GeomFunc(k, hitInfo.normal, w0, wi);

                float nDotw0 = max(dot(hitInfo.normal, w0), 0.001f);
                float nDotwi = max(dot(hitInfo.normal, wi), 0.001f);
                float nDotwh = max(dot(hitInfo.normal, wh), 0.001f);
                float w0Dotwh = max(dot(w0, wh), 0.001f);

                // PDF
                pdf = Fr * ((D_new * nDotwh) / (4.0 * w0Dotwh));
                pdf = max(pdf, 0.001f);

                // Return BRDF
                return (D_new * G_new * vec3(Fr) * nDotwi) / (4.0 * nDotwi);
            }
            // Transmit (Refract)
            else
            {
                wi = refract(-w0, wh, eta);

                // TIR Check
                if (length(wi) == 0.0)
                {
                    return vec3(0.0);
                }

                float k = (alphaSqr + 1.0) / 8.0;
                float D_new = DistrFunc(alphaSqr, hitInfo.normal, wh);
                float G_new = GeomFunc(k, hitInfo.normal, w0, wi);

                float nDotw0 = abs(dot(hitInfo.normal, w0));
                float nDotwi = abs(dot(hitInfo.normal, wi));
                float nDotwh = abs(dot(hitInfo.normal, wh));

                // USE ABSOLUTE VALUES FOR MICROFACET CHECKS
                float w0Dotwh = abs(dot(w0, wh));
                float wiDotwh = abs(dot(wi, wh));

                // PDF
                float denom = pow(dot(wi, wh) + eta * dot(w0, wh), 2.0);
                denom = max(denom, 0.0001f); // Safety clamp

                pdf = (1.0 - Fr) * (D_new * nDotwh * wiDotwh) / denom;
                pdf = max(pdf, 0.001f);

                // BTDF
                float btdf = (D_new * G_new * w0Dotwh * wiDotwh) / (nDotw0 * nDotwi * denom);
                float nDotwiT = abs(dot(hitInfo.normal, wi));
                return vec3(btdf) * (1.0 - Fr) * albedo;
            }
        }

        // ROUGH DIFFUSE
        else
        {
            float nDotwi = max(dot(hitInfo.normal, wi), 0.001f);
            float nDotw0 = max(dot(hitInfo.normal, w0), 0.001f);
            vec3 Fr = FrsRflct(wh, w0, F0);
            vec3 roughSpec = (D * G * Fr) / (4.0 * nDotw0 * nDotwi);

            // Diffuse Lobe (Lambertian)
            vec3 kD = (1.0 - Fr) * (1.0 - hitInfo.metallic); // diffuse ratio
            vec3 diffuse = (kD * albedo) / pi;

            // PBR BRDF RESULT (Direct Lighting)
            return diffuse * pi;
        }
    }

    // Error Detection
    return vec3(0.0);
}

// ========================================
// LIGHTING FUNCTIONS
// ========================================

// Point Light (No Geometry To Hit)
vec3 pointLight(pLight light, HitInfo hitInfo, vec3 wi, float dist)
{
    // PDF is 1
    // VARIABLES
    vec3 point = hitInfo.point;

    // MOST IMPORTANT > radiance = radiant flux / area * angle // radiant flux = energy / time // irradiance = energy / time * area
    // power leaving surface = power surface emits + (incoming power - absorbed power)
    // Shading is from > Radiance(color) seen in specific outgoing direction w sampled at point p on a surface (L0(p, w0) = Le(p,w0) + Lr(p, w0)) (Lr = reflected light afetr absorbtion in our direction)
    // BRDF (fr)  fr(p, wo, wi) = (d*L0(p,w0)) / (Li(p,wi)*(n*wi)d*wi)
    // fr(p, wo, wi) >= 0, BRDF never negative // fr(p, wo, wi) = fr(p,wi,w0) Helmhotz, direction of calc doesn't matter // Energy conservation, BRDF doesn't create energy

    // EMITTED RADIANCE
    dist = length(light.origin - point);
    float attentuation = 1.0 / (dist * dist); // reduce lighting effect
    wi = (light.origin - point) / dist;        // wi (incoming direction)

    // Irradiance
    vec3 Le = light.color * attentuation; // irradiance
    return Le;
}

// Directional Light (Infinite)
vec3 directionalLight(dLight light, HitInfo hitInfo, vec3 wi)
{
    // PDF is 1.0
    // Light Direction
    wi = normalize(-light.direction);

    // Irradiance
    vec3 Le = light.color;
    return Le;
}

// Area Light
vec3 areaLight(aLight light, HitInfo hitInfo, vec3 wi, float dist)
{
    // Random Values
    float X0 = RandFloat(randSample);
    float Xi = RandFloat(randSample);

    // SAMPLING
    vec3 randPoint = light.origin + (X0 * light.u) + (Xi * light.v);

    // Calculations
    float A = length(cross(light.u, light.v)); // surface area
    dist = length(randPoint - hitInfo.point);
    wi = (randPoint - hitInfo.point) / dist;

    // Irradiance
    vec3 Le = light.color / (pi * A);

    return Le;
}

// ========================================
// INTERSECTION FUNCTIONS
// ========================================

// ----------------------------------------
// LOCAL TRANSFORM PREP
// ----------------------------------------
LocalSpaceData localSpacePrep(Ray ray, uint objID)
{
    // VARIABLES
    LocalSpaceData data;
    uint crntIndx = objID;
    int prntIndx = -1;

    mat4 localTrn = mat4(1.0);
    mat4 prntTrn = mat4(1.0);

    // LOOP THROUGH INDICES
    for (int i = 0; i < xFormArray.length(); i++)
    {
        if (xFormArray[i].crntID == crntIndx)
        {
            localTrn = xFormArray[i].transform;
            prntIndx = xFormArray[i].prntID;
            break;
        }
    }

    // GLOBAL PARENT CHECK
    bool prntFound = false;
    while (prntIndx != -1) // loop until global parent
    {
        for (int i = 0; i < xFormArray.length(); i++)
        {
            if (xFormArray[i].crntID == prntIndx)
            {
                prntTrn = xFormArray[i].transform * prntTrn; // combine the parent transforms
                prntIndx = xFormArray[i].prntID;             // go to next parent
                prntFound = true;
                break;
            }
        }

        if (!prntFound)
            break;
    }

    // MATRIX MULT
    mat4 crntTrn = prntTrn * localTrn;

    // SCALE
    float scale = length(vec3(crntTrn[0]));
    float invScale = 1.0 / scale; // gets local scale (shrink ray instead of enlarge shape)

    // ROTATION
    mat3 rot = mat3(crntTrn) * invScale; // grabs rotation values and purges scale
    mat3 invRot = transpose(rot);

    // TRANSLATION
    vec3 trans = vec3(crntTrn[3]);
    vec3 invTrans = -(invRot * trans);

    // FRAME CHANGE (Global to Local)
    mat4 basisChange = mat4(vec4(invRot[0] * invScale, 0.0),   // basis change
                                        vec4(invRot[1] * invScale, 0.0),
                                        vec4(invRot[2] * invScale, 0.0),
                                        vec4(invTrans, 1.0));

    data.localRay.origin = vec3(basisChange * vec4(ray.origin, 1.0));
    data.localRay.direction = vec3(normalize(basisChange * vec4(ray.direction, 0.0)));
    data.nrmMtrx = rot;
    data.wrldToLocal = crntTrn;

    return data;
}

// ----------------------------------------
// SPHERE INTERSECTION
// ----------------------------------------
HitInfo intersectSphere(Ray ray, Sphere sphere)
{
    // VARIABLES
    LocalSpaceData ls = localSpacePrep(ray, sphere.objID);
    HitInfo hitInfo;
    hitInfo.valid = false;

    float crntDist = 0.0;
    int maxSteps = 100;

    // FIXES FOR DIELECTRICS
    float startSDF = length(ls.localRay.origin - sphere.center) - sphere.radius; // starting sdf to prevent negative distance inside sphere
    float raySign;                                                                    // essentially a flip switch to help with starting sdf

    if (startSDF < 0.0)
    {
        raySign = -1.0;
    }
    else
    {
        raySign = 1.0;
    }

    // MOTION BLUR (Move Sphere Based on Time)
    float velocity = 0.10;

    if (sphere.animated == true)
    {
        sphere.center += vec3(ray.time * velocity);
    }

    // RAY MARCHING
    for (int i = 0; i < maxSteps; i++)
    {
        // CALCULATIONS
        vec3 point = ls.localRay.origin + ls.localRay.direction * crntDist;
        float sdf = length(point - sphere.center) - sphere.radius; // signed distance function (distance from current position to object)

        float newSDF = sdf * raySign; // new sdf to prevent negative distance

        // INTERSECT CHECKS
        if (newSDF < 0.0001f)
        {
            hitInfo.valid = true;
            hitInfo.distance = crntDist;
            hitInfo.objID = sphere.objID;
            hitInfo.albedo = sphere.albedo;
            hitInfo.roughness = sphere.roughness;
            hitInfo.metallic = sphere.metallic;
            hitInfo.ior = sphere.ior;
            hitInfo.emissive = sphere.emissive;
            hitInfo.z = sphere.z;
            hitInfo.layerIOR = sphere.layerIOR;
            hitInfo.point = vec3(ls.wrldToLocal * vec4(point, 1.0));
            vec3 localNorm = normalize(point - sphere.center);
            hitInfo.normal = normalize(ls.nrmMtrx * localNorm);

            return hitInfo;
        }

        // MARCH
        crntDist += newSDF; // current step distance (how far step will travel)

        // BREAK
        if (crntDist > 100.0)
            break; // unlikely to hit, optimization
    }

    return hitInfo;
}

// ----------------------------------------
// TRIANGLE INTERSECTION
// ----------------------------------------
HitInfo intersectTriangle(Ray ray, Triangle triangle)
{
    // VARIABLES
    LocalSpaceData ls = localSpacePrep(ray, triangle.objID);
    HitInfo hitInfo;
    hitInfo.valid = false;

    vec3 edge1 = triangle.p1 - triangle.p0;
    vec3 edge2 = triangle.p2 - triangle.p0;
    vec3 h = cross(ls.localRay.direction, edge2);
    float a = dot(edge1, h);

    // CHECK FOR PARALLEL OR INSIDE PLANE OF TRIANGLE (If a is near 0)
    if (abs(a) < 0.0001)
    {
        hitInfo.valid = false;
        return hitInfo;
    }

    float f = 1.0 / a;
    vec3 s = ls.localRay.origin - triangle.p0;
    float u = f * dot(s, h);

    // INTERSECTION OUT OF TRIANGLE BOUNDS
    if (u < 0.0 || u > 1.0)
    {
        hitInfo.valid = false;
        return hitInfo;
    }

    vec3 q = cross(s, edge1);
    float v = f * dot(ls.localRay.direction, q);

    if (v < 0.0 || u + v > 1.0)
    {
        hitInfo.valid = false;
        return hitInfo;
    }

    // CALCULATE DISTANCE
    float t = f * dot(edge2, q);

    // HIT CHECK
    if (t > 0.0001) // epsilon prevent self-intersection
    {
        // Fill Hit Info Traits
        hitInfo.valid = true;
        hitInfo.objID = triangle.objID;
        hitInfo.distance = t; // distance
        hitInfo.albedo = triangle.albedo;
        hitInfo.roughness = triangle.roughness;
        hitInfo.metallic = triangle.metallic;
        hitInfo.ior = triangle.ior;
        hitInfo.emissive = triangle.emissive;
        hitInfo.z = triangle.z;
        hitInfo.layerIOR = triangle.layerIOR;
        vec3 localPoint = ls.localRay.origin + ls.localRay.direction * t; // calculate point
        hitInfo.point = vec3(ls.wrldToLocal * vec4(localPoint, 1.0));
        vec3 localNorm = cross(edge1, edge2); // calculate normal
        hitInfo.normal = normalize(ls.nrmMtrx * localNorm);
        return hitInfo;
    }

    else
    {
        hitInfo.valid = false;
    }

    return hitInfo;
}

// ----------------------------------------
// PLANE INTERSECTION
// ----------------------------------------
HitInfo intersectPlane(Ray ray, Plane plane)
{
    // VARIABLES
    LocalSpaceData ls = localSpacePrep(ray, plane.objID);
    HitInfo hitInfo;
    hitInfo.valid = false;

    float crntDist = 0.0;
    int maxSteps = 200;
    float threshold = 0.001f;

    // RAY MARCHING
    for (int i = 0; i < maxSteps; i++)
    {
        // CALCULATIONS
        vec3 point = ls.localRay.origin + ls.localRay.direction * crntDist;
        float sdf = abs(dot((point - plane.position), plane.normal)); // signed distance function (distance from current position to object)

        // INTERSECT CHECKS
        if(sdf < threshold)
        {
            hitInfo.valid = true;
            hitInfo.distance = crntDist;
            hitInfo.objID = plane.objID;
            hitInfo.albedo = plane.albedo;
            hitInfo.roughness = plane.roughness;
            hitInfo.metallic = plane.metallic;
            hitInfo.ior = plane.ior;
            hitInfo.emissive = plane.emissive;
            hitInfo.z = plane.z;
            hitInfo.layerIOR = plane.layerIOR;
            hitInfo.point = vec3(ls.wrldToLocal * vec4(point, 1.0));
            hitInfo.normal = normalize(ls.nrmMtrx * plane.normal);

            return hitInfo;
        }

        // MARCH
        crntDist += sdf; // current step distance (how far step will travel)

        // BREAK OUT
        if (crntDist > 100.0)
            break; // unlikely to hit, optimization
    }

    return hitInfo;
}

