// ========================================
// TRACER FUNCTION
// ========================================
vec3 Tracer(Ray ray)
{
    vec3 finalColor = vec3(0.0);
    vec3 tempColor = vec3(1.0); // act as if light was hit
    vec3 specCoeff = vec3(0.0);

    Ray bounceRay;

    bounceRay = ray;

    // MAX DEPTH CHECK
    for (int depthIndex = 0; depthIndex < 5; depthIndex++)
    {
        // First Intersect
        HitInfo hitInfo;
        hitInfo.valid = false;
        hitInfo.distance = 1000000.0;  

        // Check For Sphere
        HitInfo tempHit;
        int i = 0;
        for (i = 0; i < spheres.length(); i++)
        {
            tempHit = intersectSphere(bounceRay, spheres[i]);
            if (tempHit.valid && tempHit.distance < hitInfo.distance)
            {
                hitInfo = tempHit;
            }
        }

        // Check For Plane
        for (i = 0; i < planes.length(); i++)
        {
            tempHit = intersectPlane(bounceRay, planes[i]);
            if (tempHit.valid && tempHit.distance < hitInfo.distance)
            {
                hitInfo = tempHit;
            }
        }

        // Check For Triangle
        for (i = 0; i < triangles.length(); i++)
        {
            tempHit = intersectTriangle(bounceRay, triangles[i]);
            if (tempHit.valid && tempHit.distance < hitInfo.distance)
            {
                hitInfo = tempHit;
            }
        }

        // Non Light Hit
        if (hitInfo.valid && hitInfo.emissive == false)
        {
            // VARIABLES
            vec3 wiDirect;
            float pdf = 1.0;
            float lightDist = 1.0;

            // LIGHT SAMPLING & SHADOWS
            vec3 Le;
            // Le = light.pointLight(pointLight, hitInfo, wiDirect, lightDist);
            // Le = light.directionalLight(directionalLight, hitInfo, wiDirect);

            // INSTANTIATE LIGHT STRUCTS
            pLight crntPointLight;
            dLight crntDirLight;
            aLight crntAreaLight;

            if (length(crntPointLight.color) > 0.0)
            {
                Le = pointLight(crntPointLight, hitInfo, wiDirect, lightDist);
            }

            else if (length(crntAreaLight.color) > 0.0)
            {
                Le = areaLight(crntAreaLight, hitInfo, wiDirect, lightDist);
            }

            else if (length(crntDirLight.color) > 0.0)
            {
                Le = directionalLight(crntDirLight, hitInfo, wiDirect);
            }

            // Generate Shadows
            bool inShadow = false;
            Ray shadowRay;
            shadowRay.origin = hitInfo.point + (hitInfo.normal * 0.01f); // offset to avoid self shadowing
            shadowRay.direction = wiDirect;

            // Shadow Block Check Sphere
            HitInfo shadowHit;
            for (i = 0; i < spheres.length(); i++)
            {
                shadowHit = intersectSphere(shadowRay, spheres[i]);
                if (shadowHit.valid && shadowHit.distance < lightDist && hitInfo.objID != shadowHit.objID) // Check for hit and behind object
                    inShadow = true;
            }

            // Shadow Block Check Plane
            for (i = 0; i < planes.length(); i++)
            {
                shadowHit = intersectPlane(shadowRay, planes[i]);
                if (shadowHit.valid && shadowHit.distance < lightDist && hitInfo.objID != shadowHit.objID)
                    inShadow = true;
            }

            // COLOR / REFLECTANCE (BRDF)
            vec3 R = hitInfo.albedo;
            vec3 w0 = -bounceRay.direction;
            vec3 directLight = vec3(0.0);

            // Not In Shadow
            if (!inShadow)
            {
                // DIRECT LIGHTING
                vec3 rflctDirect = DirectBxDF(hitInfo, w0, wiDirect);

                float nDotWi = dot(hitInfo.normal, wiDirect); // lambert's cos law
                directLight = rflctDirect * nDotWi * Le;
            }

            // INDIRECT LIGHT
            vec3 wiIndirect;
            vec3 rflctIndirect;

            if (hitInfo.z == 0.0)
            {
                rflctIndirect = BxDF(hitInfo, w0, wiIndirect, pdf);
            }
            else
            {
                rflctIndirect = LayeredBxDF(hitInfo, w0, wiIndirect, pdf);
            }

            bounceRay.direction = wiIndirect;
            vec3 normOffset = dot(wiIndirect, hitInfo.normal) < 0.0 ? -hitInfo.normal : hitInfo.normal; // prevent self intersection
            bounceRay.origin = hitInfo.point + (normOffset * 0.002f);

            // Indirect Light Calculation
            finalColor += tempColor * directLight; 

            float nDotwi = abs(dot(hitInfo.normal, wiIndirect)); // lambert's cos law
            tempColor *= (rflctIndirect * nDotwi) / pdf;

            // COLOR CALCULATION

            // Max Radiance Clamp (Firefly fix (GREEN))
            // float maxRad = 10.0;
            // tempColor.x = min(tempColor.x, maxRad);
            // tempColor.y = min(tempColor.y, maxRad);
            // tempColor.z = min(tempColor.z, maxRad);
        }
        // Exited Scene
        else
        {
            // Set Sky Color
            finalColor += tempColor * vec3(0.69f, 0.88f, 1.0);

            break;
        }
    }

    return finalColor;
}